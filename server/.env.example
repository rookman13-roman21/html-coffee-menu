# ── Обязательно сменить ──────────────────────────────────────
JWT_SECRET=your-super-secret-key-minimum-32-characters-long

# ── Ваш admin email (первый кто зарегистрируется с этим email — получит права admin и активируется автоматически)
ADMIN_EMAIL=your@email.com

# ── БД (оставить как есть для SQLite)
DATABASE_URL=sqlite:///./data/app.db

# ── SMTP (Яндекс-почта, порт 465 SSL)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=your@yandex.ru
SMTP_PASS=your-app-password

# ── Яндекс OAuth
YANDEX_CLIENT_ID=your-client-id
YANDEX_SECRET=your-client-secret
YANDEX_REDIRECT=https://your-domain.com/api/auth/yandex/callback

# ── Telegram Bot (уведомления о регистрациях, активациях)
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_ADMIN_CHAT_ID=your-chat-id

# ── Telegram Bot @Join_MBS_bot (авторы рецептов)
JOIN_MBS_BOT_TOKEN=your-join-mbs-bot-token
JOIN_MBS_BOT_USERNAME=Join_MBS_bot
JOIN_MBS_AUTHOR_REVIEW_CHAT_ID=your-author-review-chat-id

# ── Битрикс: авторы рецептов ─────────────────────────────────
BITRIX_WEBHOOK=https://your-domain.bitrix24.ru/rest/1/your-webhook-token
BITRIX_AUTHOR_MARK_FIELD=UF_CRM_1766349995197
BITRIX_AUTHOR_MARK_LABEL=Автор рецептов
