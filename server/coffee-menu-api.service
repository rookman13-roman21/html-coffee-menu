[Unit]
Description=Coffee Menu API (FastAPI)
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/var/www/coffee-menu/server
EnvironmentFile=/var/www/coffee-menu/server/.env
ExecStart=/var/www/coffee-menu/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=3
StandardOutput=append:/var/log/coffee-menu-api.log
StandardError=append:/var/log/coffee-menu-api.log

[Install]
WantedBy=multi-user.target
